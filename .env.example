# ─── Win11 frontend ── public Vite env contract ─────────────────────────────
# Every key is prefixed with VITE_ so Vite forwards it to the browser bundle.
# NEVER store secrets here — anything in this file is publicly readable.

# ── Branding / identity ───────────────────────────────────────────────────
VITE_APP_NAME=Win11
VITE_APP_SLUG=win11
VITE_APP_TAGLINE=Fantasy Sports — Reimagined
VITE_APP_LOGO_URL=
VITE_APP_DEFAULT_CURRENCY=INR
VITE_APP_DEFAULT_LOCALE=en-IN
VITE_APP_VERSION=0.1.0
VITE_APP_ENV=development

# API (backend modular monolith — see ../backend)
VITE_API_BASE_URL=http://localhost:4000
VITE_API_PREFIX=/api/v1
VITE_API_TIMEOUT_MS=15000

# Socket.io
VITE_SOCKET_URL=http://localhost:4000
VITE_SOCKET_PATH=/socket.io
VITE_SOCKET_TRANSPORTS=websocket,polling

# Theme engine
VITE_DEFAULT_THEME_ID=light
VITE_DEFAULT_THEME_MODE=light
VITE_THEME_REMOTE_CONFIG_ENABLED=false

# Feature flags (phase 1 → all features off until later phases land)
VITE_FEATURE_PWA=false
VITE_FEATURE_ANALYTICS=false
